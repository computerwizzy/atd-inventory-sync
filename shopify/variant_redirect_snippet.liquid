{%- comment -%}
  Variant Redirect Rescue
  -----------------------
  Paste this inside <head> in theme.liquid (or in a dedicated snippet you include
  from theme.liquid). It runs on EVERY page, but only acts when:
    1. The URL contains ?variant=<id>
    2. The <id> exists in our rescue map (old Method product variants)

  When a match is found, it performs a 301-equivalent client redirect to the
  matching NEW product handle. If the path already is the new product, it does
  nothing (prevents redirect loops).

  If Shopify still serves the OLD product for a legacy handle, this snippet
  runs INSIDE that page render and bounces the visitor before they see stale
  content.

  Update the JSON below any time the mapping changes — it's generated by
  build_variant_redirect_map.py.
{%- endcomment -%}

<script>
(function () {
  // Inlined JSON: oldVariantId -> newHandle
  var MAP = /*VARIANT_MAP_JSON*/;

  try {
    var params = new URLSearchParams(window.location.search);
    var vid = params.get('variant');
    if (!vid) return;

    var target = MAP[vid];
    if (!target) return;

    var targetPath = '/products/' + target;
    if (window.location.pathname === targetPath) return; // already there

    // Preserve any non-variant query params (utm_*, ref, etc.)
    params.delete('variant');
    var extra = params.toString();
    var url = targetPath + (extra ? ('?' + extra) : '');

    // Use replace() so this doesn't pollute browser history (acts like 301)
    window.location.replace(url);
  } catch (e) {
    // fail silently — never break the storefront over a redirect
  }
})();
</script>
